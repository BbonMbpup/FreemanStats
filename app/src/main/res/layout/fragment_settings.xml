<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Настройки клана"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Текущий тег клана:"
            android:textSize="16sp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/currentClanTagTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"
            android:textColor="@color/purple"/>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:hint="Новый тег клана">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/newClanTagEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapCharacters"
                android:maxLines="1"/>

        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/changeClanTagButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Изменить тег клана"
            android:layout_marginBottom="16dp"
            style="@style/Widget.Material3.Button.OutlinedButton"/>
 
        <Button
            android:id="@+id/resetClanTagButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Сбросить тег клана"
            android:layout_marginBottom="24dp"
            style="@style/Widget.Material3.Button.OutlinedButton"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@android:color/darker_gray"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/openLaunchActivityButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Открыть экран приветствия"
            style="@style/Widget.Material3.Button"/>

    </LinearLayout>
</ScrollView>